# =============================================================================
# DTU Linux Setup – runtime answers
# =============================================================================
# This file pre-fills the prompts shown by the GUI. Load it via
# "☰ Load env file…" in the main window. Anything left blank or commented
# falls back to the normal interactive dialog.
#
# Format: shell-style KEY=VALUE, one per line. The 'export ' prefix and
# '#' comments are allowed. Values may be quoted with " or '.
#
# Tip for headless deployments: combine with a custom site.conf in
# /etc/dtu-setup/site.conf and you can run "Run All Admin Modules" without
# any prompts.
# =============================================================================

# ─── Department selector (sustain | ait) ────────────────────────────────────
DTU_DEPARTMENT="sustain"

# ─── Domain Join ────────────────────────────────────────────────────────────
# Hostname the machine should be renamed to (uppercase by convention).
DTU_HOSTNAME="SUS-EL-EXAMPLE01"
# Domain admin used to join the realm. Password is asked interactively in
# a Konsole window started by domain-join.sh — never put it in this file.
DTU_ADMIN_USERNAME="adm-username"

# ─── Domain user credentials (Q/P/M-drive, FollowMe, WiFi, OneDrive) ────────
# Leave commented in shared deployments — the GUI will then prompt.
#DTU_USERNAME="mpark"
#DTU_PASSWORD="…"   # sensitive: prefer interactive entry

# ─── Software module ────────────────────────────────────────────────────────
# Override the path to software.conf (defaults to the bundled one).
#DTU_SOFTWARE_CONF="/etc/dtu-setup/software.conf"
# Absolute path to the Cisco Secure Client tarball (auto-detected if empty).
#DTU_CISCO_TARBALL="/opt/cisco/cisco-secure-client-linux64-5.1.10.233-predeploy-k9.tar.gz"
