# =============================================================================
# DTU Sustain – Site configuration
# =============================================================================
# Hand this file to IT administrators who want to run DTU Linux Setup on
# DTU Sustain workstations.
#
# Install with:
#   sudo install -d /etc/dtu-setup
#   sudo install -m 0644 dtu-sustain.env /etc/dtu-setup/site.conf
#   echo "sustain" | sudo tee /etc/dtu-setup/department
# =============================================================================

# ─── Department flag ─────────────────────────────────────────────────────────
# Also written to /etc/dtu-setup/department by the GUI dropdown.
DTU_DEPARTMENT="sustain"

# ─── Active Directory ────────────────────────────────────────────────────────
SITE_AD_DOMAIN="WIN.DTU.DK"
SITE_AD_REALM="win.dtu.dk"
SITE_AD_ADMIN_GROUP="SUS-ITAdm-Client-Admins"

# ─── File servers ────────────────────────────────────────────────────────────
SITE_FILE_SERVER="<fileserver>"
SITE_FILE_SERVER_QUMULO="<qumulo-server>"
SITE_SUSTAIN_Q_SHARE="Qdrev/SUS"
SITE_SUSTAIN_P_SUBPATH="Qdrev/SUS/Personal"

# ─── M-Drive (personal home, Users0..Users9) ────────────────────────────────
# The personal M-Drive is a central drive that applies to Sustain users too.
# It is mounted read/write at /mnt/Mdrev but NOT used by sync-homedir (sync
# continues to target the P-Drive on Qumulo). Point SITE_MDRIVE_SERVER at the
# CIFS host that serves the personal homes; SITE_MDRIVE_BASE is the top share
# holding Users0..Users9 (note the literal $ in the share name).
SITE_MDRIVE_SERVER="<qumulo-server>"
SITE_MDRIVE_BASE="Users$"

# ─── Printing — classic FollowMe via CUPS/SMB ────────────────────────────────
SITE_PRINT_SERVER="konfigureret via site.conf"
# SITE_WEBPRINT_URL is unused on Sustain (kept here for reference)
SITE_WEBPRINT_URL="https://webprint.dtu.dk"

# ─── WiFi ────────────────────────────────────────────────────────────────────
SITE_WIFI_SSID="DTUSecure"

SITE_WIFI_IDENTITY_SUFFIX="@win.dtu.dk"

# ─── Microsoft Defender ──────────────────────────────────────────────────────
SITE_DEFENDER_ONBOARDING_URL="konfigureret via site.conf/download/MicrosoftDefenderATPOnboardingLinuxServer.py"

# ─── Helpdesk (used in welcome dialog) ───────────────────────────────────────
SITE_HELPDESK_URL="https://serviceportal.dtu.dk"SITE_HELPDESK_EMAIL="ait@dtu.dk"