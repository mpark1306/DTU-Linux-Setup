# =============================================================================
# DTU AIT – Site configuration
# =============================================================================
# Hand this file to IT administrators who want to run DTU Linux Setup on
# DTU AIT workstations.
#
# Install with:
#   sudo install -d /etc/dtu-setup
#   sudo install -m 0644 dtu-ait.env /etc/dtu-setup/site.conf
#   echo "ait" | sudo tee /etc/dtu-setup/department
#
# AIT-specific drive map:
#   O-Drev → shared department drive (set SITE_AIT_O_SHARE below)
#   M-Drev → personal home, located under konfigureret via site.confUsers0..9/<initialer>
#            (auto-discovered by qdrive.sh)
# =============================================================================

# ─── Department flag ─────────────────────────────────────────────────────────
DTU_DEPARTMENT="ait"

# ─── Active Directory ────────────────────────────────────────────────────────
SITE_AD_DOMAIN="WIN.DTU.DK"
SITE_AD_REALM="win.dtu.dk"
# Admin group used for sudo + polkit. Adjust to AIT's actual AD group.
SITE_AD_ADMIN_GROUP="AIT-Linux-Admins"

# ─── File servers ────────────────────────────────────────────────────────────
SITE_FILE_SERVER="<fileserver>"
SITE_FILE_SERVER_QUMULO="<qumulo-server>"
# Base path on file server where personal user folders live (Users0..Users9).
SITE_USERS_BASE="Users"

# ─── M-Drive + O-Drive (AIT) ────────────────────────────────────────────────
# The personal M-Drive and shared O-Drive both live on the central home
# server. Point SITE_MDRIVE_SERVER at the CIFS host that serves them
# (e.g. the Qumulo backend). SITE_MDRIVE_BASE is the top share that holds
# Users0..Users9 (note the literal $ in the share name).
SITE_MDRIVE_SERVER="<qumulo-server>"
SITE_MDRIVE_BASE="Users$"
# AIT O-Drev share path on SITE_MDRIVE_SERVER (fixed, not scanned).
# Leave empty to skip mounting O-Drev.
SITE_AIT_O_SHARE="2adm$/AIT"

# ─── Printing — WebPrint webapp (Chromium --app= mode) ───────────────────────
SITE_WEBPRINT_URL="https://webprint.dtu.dk"
# SITE_PRINT_SERVER is unused on AIT (kept here for reference)
SITE_PRINT_SERVER="konfigureret via site.conf"

# ─── WiFi ────────────────────────────────────────────────────────────────────
SITE_WIFI_SSID="DTUSecure"
SITE_WIFI_ANON_IDENTITY="anonymous@win.dtu.dk"
SITE_WIFI_IDENTITY_SUFFIX="@win.dtu.dk"

# ─── Microsoft Defender ──────────────────────────────────────────────────────
SITE_DEFENDER_ONBOARDING_URL="konfigureret via site.conf/download/MicrosoftDefenderATPOnboardingLinuxServer.py"

# ─── Ansible onboarding ──────────────────────────────────────────────────────
# AIT may use a different service account name. Update as needed.
SITE_ANSIBLE_USER="ait-root"

# ─── Helpdesk (used in welcome dialog) ───────────────────────────────────────
SITE_HELPDESK_URL="https://helpdesk.dtu.dk"
SITE_HELPDESK_EMAIL="ait@dtu.dk"
